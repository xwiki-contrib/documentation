    <property type="LargeString">
      <code>{{velocity}}
#set ($image = $xcontext.macro.params.reference)
## TODO: Remove the width parameter in the future when all doc pages on xwiki.org have stopped.
## using the width parameter for the size one.
#set ($width = "$!xcontext.macro.params.width")
#set ($size = "$!xcontext.macro.params.size")
## TODO: Remove this validation when the width parameter has been removed.
## Validation: image macro used for documentation in the Doc space (i.e. new docs) must use the size parameter and not use the width parameter
#if ('documentation' == $doc.getDocumentReference().extractFirstReference('SPACE').getName() &amp;&amp; ("$!width" != '' || "$!size" == ''))
  {{error}}Best practice: The Image macro, when used in the "documentation" space, must specify a 'size' parameter and no 'width' one.{{/error}}
#else
  #if ($size == 'small')
    #set ($width = "150px")
  #elseif ($size == 'medium')
    #set ($width = "350px")
  #elseif ($size == 'large')
    #set ($width = "650px")
  #elseif ($size == 'extra')
    #set ($width = "960px")
  #end
  #set ($caption = "$!xcontext.macro.params.caption")
  (% style="display: inline-block; border:1px solid silver; max-width:100%;#if ($width != '') width:$width;#end" %)[[image:$image||style="width:100%"]](%%)
  #if ($caption != '')
    //${caption}//
  #end
#end
{{/velocity}}</code>
