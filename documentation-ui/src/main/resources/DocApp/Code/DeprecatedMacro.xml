  <version>1.1</version>
  <title>Deprecated Macro</title>
  <comment/>
  <minorEdit>false</minorEdit>
  <syntaxId>xwiki/2.1</syntaxId>
  <hidden>true</hidden>
  <content>= Example 1: Basic usage =

{{code}}
{{deprecated since='11.10.5' useInstead='the New Feature'}}
Content that was deprecated...
{{/deprecated}}
{{/code}}

Results in:

{{deprecated since="11.10.5" useInstead="the New Feature"}}
Content that was deprecated...
{{/deprecated}}

= Example 2: Different product =

{{code}}
{{deprecated product='Latex' since='11.10.5' useInstead='the New Feature'}}
Content that was deprecated...
{{/deprecated}}
{{/code}}

Results in:

{{deprecated product="Latex" since="11.10.5" useInstead="the New Feature"}}
Content that was deprecated...
{{/deprecated}}</content>
